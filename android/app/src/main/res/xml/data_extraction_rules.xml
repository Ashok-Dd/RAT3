<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) requires this file when
    android:dataExtractionRules is declared in the manifest.
    RAT3 excludes all data from cloud backup — scan results are ephemeral.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>